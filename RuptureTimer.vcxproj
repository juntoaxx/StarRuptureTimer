<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="..\Shared.props" />
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Client Debug|x64">
      <Configuration>Client Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Client Release|x64">
      <Configuration>Client Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <RootNamespace>RuptureTimer</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Client Debug' Or '$(Configuration)'=='Debug'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v145</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Client Release' Or '$(Configuration)'=='Release'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v145</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <!-- ── Output directory ───────────────────────────────────────────────────── -->
  <PropertyGroup>
    <OutDir>$(SolutionDir)bin\$(Platform)\$(Configuration)\plugins\</OutDir>
    <IntDir>$(SolutionDir)obj\$(ProjectName)\$(Platform)\$(Configuration)\</IntDir>
    <TargetName>StarRuptureTimer</TargetName>
  </PropertyGroup>
  <!-- ── Compiler settings (all configs) ───────────────────────────────────── -->
  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <AdditionalIncludeDirectories>$(ProjectDir)..\include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalDependencies>kernel32.lib;user32.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <!-- ── Client Debug ───────────────────────────────────────────────────────── -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Client Debug'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>MODLOADER_CLIENT_BUILD;_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(ProjectDir)..\StarRupture SDK\Client\;$(ProjectDir)..\StarRupture SDK\Client\SDK\;$(ProjectDir)..\include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <WarningLevel>TurnOffAllWarnings</WarningLevel>
    </ClCompile>
  </ItemDefinitionGroup>
  <!-- ── Client Release ─────────────────────────────────────────────────────── -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Client Release'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>MODLOADER_CLIENT_BUILD;NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(ProjectDir)..\StarRupture SDK\Client\;$(ProjectDir)..\StarRupture SDK\Client\SDK\;$(ProjectDir)..\include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <WarningLevel>TurnOffAllWarnings</WarningLevel>
    </ClCompile>
    <Link>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
    </Link>
  </ItemDefinitionGroup>
  <!-- ── Debug ──────────────────────────────────────────────────────────────── -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>
  <!-- ── Release ────────────────────────────────────────────────────────────── -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
    </Link>
  </ItemDefinitionGroup>
  <!-- ── Source files ───────────────────────────────────────────────────────── -->
  <ItemGroup>
    <ClCompile Include="dllmain.cpp" />
    <ClCompile Include="plugin.cpp" />
    <!-- SDK source files (compiled for client/server builds only) -->
    <ClCompile Include="..\StarRupture SDK\Client\SDK\Basic.cpp" Condition="'$(Configuration)'=='Client Debug' Or '$(Configuration)'=='Client Release'">
      <WarningLevel>TurnOffAllWarnings</WarningLevel>
      <Visible>false</Visible>
    </ClCompile>
    <ClCompile Include="..\StarRupture SDK\Client\SDK\CoreUObject_functions.cpp" Condition="'$(Configuration)'=='Client Debug' Or '$(Configuration)'=='Client Release'">
      <WarningLevel>TurnOffAllWarnings</WarningLevel>
      <Visible>false</Visible>
    </ClCompile>
    <ClCompile Include="..\StarRupture SDK\Client\SDK\Engine_functions.cpp" Condition="'$(Configuration)'=='Client Debug' Or '$(Configuration)'=='Client Release'">
      <WarningLevel>TurnOffAllWarnings</WarningLevel>
      <Visible>false</Visible>
    </ClCompile>
    <ClCompile Include="..\StarRupture SDK\Client\SDK\Chimera_functions.cpp" Condition="'$(Configuration)'=='Client Debug' Or '$(Configuration)'=='Client Release'">
      <WarningLevel>TurnOffAllWarnings</WarningLevel>
      <Visible>false</Visible>
    </ClCompile>
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="plugin.h" />
    <ClInclude Include="plugin_helpers.h" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
